{
  "name": "@syncrona/mcp-server",
  "version": "0.9.0",
  "description": "MCP server for SyncroNow AI automation and script execution",
  "main": "./dist/index.js",
  "bin": {
    "syncrona-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --enable-source-maps --test test/*.test.js",
    "test:coverage": "npm run build && node --enable-source-maps --test --experimental-test-coverage test/*.test.js",
    "test:coverage:gate": "npm run build && node scripts/check-coverage-gate.js --line-threshold 90 --branch-threshold 80",
    "test:coverage:gate100": "npm run build && node scripts/check-coverage-gate.js --line-threshold 100",
    "quality-gates": "bash scripts/quality-gates.sh",
    "check-tool-contract": "node scripts/check-tool-contract.js",
    "check-docs-drift": "node scripts/check-docs-drift.js",
    "check-claude-docs-drift": "node scripts/check-claude-docs-drift.js",
    "validate-release-checklist": "node scripts/validate-release-checklist.js",
    "prepack": "tsc"
  },
  "author": "Ivan Baev",
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.3",
    "@syncrona/credential-store": "^0.9.0",
    "@syncrona/jira": "^0.9.0",
    "@syncrona/sn-transport": "^0.9.0",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "~5.9.3"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IvanBBaev/syncrona.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://ivanbbaev.github.io/syncrona/"
}
